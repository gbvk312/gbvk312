# Lychee Configuration for Automation Architect Profile

# Ignore specific transient or expected errors
exclude = [
    # The snake SVG returns 404 until the generate-snake workflow runs for the first time
    'https://raw.githubusercontent.com/gbvk312/gbvk312/output/github-contribution-grid-snake.svg',
    
    # Ignore email addresses
    'mailto:.*',
]

# Accept 503 and 504 as non-failures for known flaky Vercel apps
accept = [
    '503',
    '504',
]

# Retry settings for potentially transient errors
max_retries = 3
retry_wait_time = 5

# Output format
format = "markdown"
verbose = true
